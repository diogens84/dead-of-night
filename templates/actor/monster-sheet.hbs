<form class="{{cssClass}} flexcol don-monster-sheet" autocomplete="off">
  
  {{!-- Header --}}
  <header class="sheet-header flexrow">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"/>
    <div class="header-details flexcol">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Monster Name"/>
      </h1>
      
      <div class="sp-bar flexrow">
        <div class="sp-label">
          <i class="fas fa-biohazard"></i> {{localize "DON.SurvivalPoints"}}:
        </div>
        <div class="sp-inputs flexrow">
          <input type="number" name="system.survivalPoints.value" value="{{system.survivalPoints.value}}" min="0" class="sp-value-input"/>
          <span> / </span>
          <input type="number" name="system.survivalPoints.max" value="{{system.survivalPoints.max}}" min="1" class="sp-value-input"/>
        </div>
      </div>
    </div>
  </header>

  {{!-- Navigation Tabs --}}
  <nav class="sheet-tabs tabs flexrow" data-group="primary">
    <a class="item" data-tab="main"><i class="fas fa-claw-marks"></i> {{localize "DON.Attributes"}}</a>
    <a class="item" data-tab="vulnerabilities"><i class="fas fa-heart-crack"></i> {{localize "DON.Vulnerabilities"}}</a>
    <a class="item" data-tab="biography"><i class="fas fa-book-dead"></i> {{localize "DON.Biography"}}</a>
  </nav>

  <section class="sheet-body">

    {{!-- MAIN TAB --}}
    <div class="tab main flexcol" data-group="primary" data-tab="main">
      <div class="monster-attributes-grid">
        {{#each attributesList}}
          <div class="monster-attr-card flexrow">
            <button type="button" class="roll-attribute" data-attribute="{{this.key}}" title="{{localize 'DON.Roll'}} {{this.label}}">
              <i class="fas fa-dice-d20"></i>
            </button>
            <span class="attr-name">{{this.label}}</span>
            <input type="number" name="system.attributes.{{this.key}}" value="{{this.val}}" min="0" class="monster-attr-input"/>
          </div>
        {{/each}}
      </div>

      {{!-- MONSTROUS ABILITIES --}}
      <div class="abilities-section flexcol">
        <div class="section-header flexrow">
          <h3><i class="fas fa-skull-crossbones"></i> {{localize "DON.MonstrousAbilities"}}</h3>
          <a class="ability-create" title="{{localize 'DON.AddMonstrousAbility'}}">
            <i class="fas fa-plus"></i> {{localize "DON.AddMonstrousAbility"}}
          </a>
        </div>
        <ul class="items-list">
          {{#each abilities}}
            <li class="item flexrow" data-item-id="{{this._id}}">
              <img class="item-img" src="{{this.img}}" width="24" height="24"/>
              <span class="item-name">{{this.name}}</span>
              <span class="item-cost badge">{{localize "DON.Cost"}}: {{this.system.cost}}</span>
              <div class="item-controls">
                <a class="item-edit" title="Edit"><i class="fas fa-edit"></i></a>
                <a class="item-delete" title="Delete"><i class="fas fa-trash"></i></a>
              </div>
            </li>
          {{/each}}
        </ul>
      </div>
    </div>

    {{!-- VULNERABILITIES TAB --}}
    <div class="tab vulnerabilities flexcol" data-group="primary" data-tab="vulnerabilities">
      <div class="editor-container">
        {{editor system.vulnerabilities target="system.vulnerabilities" button=true owner=owner editable=editable}}
      </div>
    </div>

    {{!-- BIOGRAPHY TAB --}}
    <div class="tab biography flexcol" data-group="primary" data-tab="biography">
      <div class="editor-container">
        {{editor system.biography target="system.biography" button=true owner=owner editable=editable}}
      </div>
    </div>

  </section>
</form>
