<form class="{{cssClass}} flexcol don-character-sheet" autocomplete="off">
  
  {{!-- Sheet Header --}}
  <header class="sheet-header flexrow">
    <img class="profile-img" src="{{actor.img}}" data-edit="img" title="{{actor.name}}"/>
    <div class="header-details flexcol">
      <h1 class="charname">
        <input name="name" type="text" value="{{actor.name}}" placeholder="Nombre del Personaje" style="color: #ffffff !important; background-color: #1c2029 !important;"/>
      </h1>

      <div class="concept-habits-row flexrow">
        <div class="field-group flexrow">
          <label style="color: #ffffff !important;"><i class="fas fa-user-tag"></i> {{localize "DON.Concept"}}:</label>
          <input name="system.concept" type="text" value="{{system.concept}}" placeholder="{{localize 'DON.Concept'}}" style="color: #ffffff !important; background-color: #1c2029 !important;"/>
        </div>
        <div class="field-group flexrow">
          <label style="color: #ffffff !important;"><i class="fas fa-smoking"></i> {{localize "DON.BadHabits"}}:</label>
          <input name="system.badHabits" type="text" value="{{system.badHabits}}" placeholder="{{localize 'DON.BadHabits'}}" style="color: #ffffff !important; background-color: #1c2029 !important;"/>
        </div>
      </div>
      
      <div class="sp-bar flexrow">
        <div class="sp-label" style="color: #ef4444 !important;">
          <i class="fas fa-heart-pulse"></i> {{localize "DON.SurvivalPoints"}}:
        </div>
        <div class="sp-inputs flexrow" style="color: #ffffff !important;">
          <input type="number" name="system.survivalPoints.value" value="{{system.survivalPoints.value}}" min="0" max="5" class="sp-value-input" style="color: #ffffff !important; background-color: #1c2029 !important;"/>
          <span style="color: #ffffff !important;"> / </span>
          <span class="sp-max" style="color: #ffffff !important;">{{system.survivalPoints.max}}</span>
        </div>
        <button type="button" class="spend-sp-btn" title="{{localize 'DON.SpendSPTooltip'}}" style="color: #ffffff !important;">
          <i class="fas fa-skull"></i> {{localize 'DON.SpendSP'}}
        </button>
      </div>
    </div>
  </header>

  {{!-- Single Continuous Sheet Body --}}
  <section class="sheet-body flexcol">

    {{!-- ATTRIBUTES SECTION --}}
    <div class="sheet-section attributes-section flexcol">
      <div class="section-header flexrow">
        <h3 style="color: #ef4444 !important;"><i class="fas fa-shield-halved"></i> {{localize "DON.Attributes"}}</h3>
      </div>
      <div class="attributes-grid">
        {{#each attributePairs}}
          <div class="attribute-pair-card flexcol">
            <div class="pair-labels flexrow">
              <div class="attr-side left flexrow">
                <button type="button" class="roll-attribute" data-attribute="{{this.keyA}}" title="{{localize 'DON.Roll'}} {{this.labelA}}">
                  <i class="fas fa-dice-d20"></i>
                </button>
                <span class="attr-name" style="color: #ffffff !important;">{{this.labelA}}</span>
                <span class="attr-val" data-key="{{this.keyA}}" style="color: #d97706 !important;" title="Efectivo: {{this.valA}} (Base: {{this.baseValA}})">{{this.valA}}</span>
              </div>

              <div class="attr-side right flexrow">
                <span class="attr-val" data-key="{{this.keyB}}" style="color: #d97706 !important;" title="Efectivo: {{this.valB}} (Base: {{this.baseValB}})">{{this.valB}}</span>
                <span class="attr-name" style="color: #ffffff !important;">{{this.labelB}}</span>
                <button type="button" class="roll-attribute" data-attribute="{{this.keyB}}" title="{{localize 'DON.Roll'}} {{this.labelB}}">
                  <i class="fas fa-dice-d20"></i>
                </button>
              </div>
            </div>

            <div class="slider-container flexrow">
              <input type="range" 
                     name="system.attributes.{{this.keyA}}" 
                     value="{{this.baseValA}}" 
                     min="0" 
                     max="10" 
                     class="attr-slider" 
                     data-key-a="{{this.keyA}}" 
                     data-key-b="{{this.keyB}}"/>
            </div>
          </div>
        {{/each}}
      </div>
    </div>

    {{!-- SPECIALISATIONS SECTION --}}
    <div class="sheet-section specialisations-section flexcol">
      <div class="section-header flexrow">
        <h3 style="color: #ef4444 !important;"><i class="fas fa-feather"></i> {{localize "DON.Specialisations"}}</h3>
        <button type="button" class="item-create-btn item-create" data-type="specialisation" title="{{localize 'DON.AddSpecialisation'}}" style="color: #ffffff !important; background-color: #1c2029 !important;">
          <i class="fas fa-plus"></i> {{localize "DON.AddSpecialisation"}}
        </button>
      </div>
      <ul class="items-list">
        {{#each specialisations}}
          <li class="item flexrow" data-item-id="{{this._id}}">
            <img class="item-img" src="{{this.img}}" width="24" height="24"/>
            <span class="item-name" style="color: #ffffff !important;">{{this.name}}</span>
            <span class="item-pair badge" style="color: #d8dee9 !important; background-color: #2e3440 !important;">{{this.pairLabel}}</span>
            <span class="item-bonus badge highlight" title="Max(Pair) + 2" style="color: #d97706 !important; border-color: #d97706 !important;">Valoración: {{this.derivedRating}}</span>
            <div class="item-controls flexrow">
              <a class="roll-specialisation" title="{{localize 'DON.Roll'}}"><i class="fas fa-dice-d20" style="color: #ef4444 !important;"></i></a>
              <a class="item-edit" title="Editar"><i class="fas fa-edit" style="color: #d8dee9 !important;"></i></a>
              <a class="item-delete" title="Borrar"><i class="fas fa-trash" style="color: #d8dee9 !important;"></i></a>
            </div>
          </li>
        {{/each}}
      </ul>
    </div>

    {{!-- CLICHES SECTION --}}
    <div class="sheet-section cliches-section flexcol">
      <div class="section-header flexrow">
        <h3 style="color: #ef4444 !important;"><i class="fas fa-mask"></i> {{localize "DON.Cliches"}}</h3>
      </div>
      <textarea name="system.cliches" class="don-textarea" rows="4" placeholder="Escribe aquí los Clichés y Arquetipos..." style="color: #ffffff !important; background-color: #1c2029 !important;">{{system.cliches}}</textarea>
    </div>

    {{!-- BIOGRAPHY SECTION --}}
    <div class="sheet-section biography-section flexcol">
      <div class="section-header flexrow">
        <h3 style="color: #ef4444 !important;"><i class="fas fa-book-dead"></i> {{localize "DON.Biography"}}</h3>
      </div>
      <textarea name="system.biography" class="don-textarea" rows="4" placeholder="Escribe aquí la Biografía o Notas del personaje..." style="color: #ffffff !important; background-color: #1c2029 !important;">{{system.biography}}</textarea>
    </div>

  </section>
</form>
